          ]
        },
        {
          "name": "31. List accounts after cleanup",
          "request": {
            "method": "GET",
            "description": "Final verification that account `usedBytes` returned to the imported baseline after all test objects were deleted.",
            "url": "{{baseUrl}}/admin/accounts"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Final admin accounts returns HTTP 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "const byId = Object.fromEntries((body.accounts || []).map((account) => [account.accountId, account]));",
                  "const account01Id = pm.collectionVariables.get('account01Id');",
                  "const account02Id = pm.collectionVariables.get('account02Id');",
                  "const baseline01 = Number(pm.collectionVariables.get('baselineAccount01UsedBytes') || 0);",
                  "const baseline02 = Number(pm.collectionVariables.get('baselineAccount02UsedBytes') || 0);",
                  "",
                  "pm.test('usedBytes returned to baseline after cleanup', function () {",
                  "  pm.expect(Number(byId[account01Id].usedBytes)).to.eql(baseline01);",
                  "  pm.expect(Number(byId[account02Id].usedBytes)).to.eql(baseline02);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
