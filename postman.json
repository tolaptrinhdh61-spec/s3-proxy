          "name": "30. DELETE logical bucket",
          "request": {
            "method": "DELETE",
            "description": "Delete the logical bucket after all active objects have been removed.",
            "url": "{{baseUrl}}/{{logicalBucket}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
