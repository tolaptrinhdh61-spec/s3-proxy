# ─────────────────────────────────────────────────────────────────
# .env.example — S3 Multi-Account Proxy
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────

# Client authentication key — sent as x-api-key header
PROXY_API_KEY=

# Firebase Realtime Database URL (e.g. https://<project-id>.firebaseio.com)
FIREBASE_RTDB_URL=

# Firebase RTDB legacy secret token (from Firebase Console > Project Settings > Service Accounts)
FIREBASE_DB_SECRET=

# ── OPTIONAL (defaults shown) ─────────────────────────────────────

# Port the HTTP server listens on
PORT=3000

# Switch to next account when usage reaches this fraction (0.0–1.0)
QUOTA_THRESHOLD=0.90

# How often (ms) to poll Supabase for actual storage usage
QUOTA_POLL_INTERVAL_MS=300000

# Max RTDB writes per batch during startup sync
RTDB_SYNC_BATCH_SIZE=400

# Graceful shutdown drain window in milliseconds
DRAIN_TIMEOUT_MS=30000

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Webhook URL for critical alerts (storage_full, rtdb_disconnect, etc.)
# Leave empty to disable
WEBHOOK_ALERT_URL=

# Unique identifier for this instance (auto-generated if not set)
# Useful in Docker Compose: INSTANCE_ID=proxy-1
INSTANCE_ID=

# Path to the SQLite database file
SQLITE_PATH=./data/routes.db

# LRU cache max entries
LRU_MAX=10000

# LRU cache TTL in milliseconds (5 minutes)
LRU_TTL_MS=300000
